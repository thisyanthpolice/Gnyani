# ============================================
# RAG Chatbot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
#   cp .env.example .env

# ---- OpenAI ----
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- PostgreSQL ----
# Format: postgresql+asyncpg://user:password@host:port/dbname
# For local dev: install PostgreSQL, create a DB called "ragchatbot"
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ragchatbot

# ---- Redis (Optional - for caching) ----
# Install Redis locally or use a cloud provider
# Leave empty to disable caching
REDIS_URL=redis://localhost:6379/0

# ---- FAISS Storage Path ----
FAISS_INDEX_DIR=./faiss_indexes
